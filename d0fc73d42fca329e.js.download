        id
        type
        name
        authorizations {
          createPublicRepl: createRepl(private: false) {
            isAuthorized
            message
          }
          createPrivateRepl: createRepl(private: true) {
            isAuthorized
            message
          }
          createProject {
            isAuthorized
            message
          }
        }
      }
      project {
        id
      }
    }
  }
}
